@page "/terms"
@using Xqare.Wrappers.CommonWrapper

<section class="legal-page">

    <MudPaper Class="legal-hero">

        <MudContainer MaxWidth="MaxWidth.Large">

            <MudText Typo="Typo.h3" Align="Align.Center" Class="hero-title">
                Terms & Conditions
            </MudText>

            <MudText Typo="Typo.subtitle1" Align="Align.Center">
                Effective Date: January 2026
            </MudText>

        </MudContainer>

    </MudPaper>


    <MudContainer MaxWidth="MaxWidth.Medium" Class="legal-container">

        <MudPaper Elevation="1" Class="legal-card">

            <MudText Typo="Typo.h5" Class="section-title">
                1. Acceptance of Terms
            </MudText>

            <MudText Class="section-text">
                By accessing or using the XQARE platform, you agree to be bound by these Terms & Conditions.
                If you do not agree with any part of these terms, you should discontinue use of the platform.
            </MudText>


            <MudText Typo="Typo.h5" Class="section-title">
                2. About XQARE
            </MudText>

            <MudText Class="section-text">
                XQARE is a professional mentorship and career ecosystem designed to connect students,
                early-career professionals, experienced professionals, and mentors for learning,
                networking, and career growth.
            </MudText>


            <MudText Typo="Typo.h5" Class="section-title">
                3. Eligibility
            </MudText>

            <MudText Class="section-text">
                Users must be at least 18 years old to register on the platform.
                Individuals under 18 may use the platform only with the consent of a parent or legal guardian.
            </MudText>


            <MudText Typo="Typo.h5" Class="section-title">
                4. User Accounts
            </MudText>

            <MudList T="string" Dense="true">
                <MudListItem>You are responsible for maintaining the confidentiality of your account credentials.</MudListItem>
                <MudListItem>You agree to provide accurate and up-to-date information.</MudListItem>
                <MudListItem>XQARE may suspend or terminate accounts that provide misleading or false information.</MudListItem>
            </MudList>


            <MudText Typo="Typo.h5" Class="section-title">
                5. Membership Plans
            </MudText>

            <MudText Class="section-text">
                XQARE may offer free, paid, or special membership tiers including Founding Membership.
                Each plan provides specific features which will be clearly described at the time of registration.
            </MudText>


            <MudText Typo="Typo.h5" Class="section-title">
                6. Founding Member Disclaimer
            </MudText>

            <MudText Class="section-text">
                Founding Membership does not grant equity, ownership, profit-sharing, or
                any financial stake in the XQARE company.
            </MudText>


            <MudText Typo="Typo.h5" Class="section-title">
                7. Platform Use Rules
            </MudText>

            <MudList T="string" Dense="true">
                <MudListItem>No harassment, abuse, or harmful conduct toward other users.</MudListItem>
                <MudListItem>No spam, fraudulent activities, or illegal actions.</MudListItem>
                <MudListItem>No misuse of mentor access or community features.</MudListItem>
                <MudListItem>No copying, redistribution, or misuse of platform materials without permission.</MudListItem>
            </MudList>


            <MudText Typo="Typo.h5" Class="section-title">
                8. Intellectual Property
            </MudText>

            <MudText Class="section-text">
                All platform content including logos, branding, text, graphics, and materials
                are the intellectual property of XQARE unless otherwise stated.
                Unauthorized reproduction or distribution is prohibited.
            </MudText>


            <MudText Typo="Typo.h5" Class="section-title">
                9. Payments
            </MudText>

            <MudText Class="section-text">
                Payments for paid memberships or services are processed securely through
                third-party payment providers. XQARE does not store sensitive payment details.
            </MudText>


            <MudText Typo="Typo.h5" Class="section-title">
                10. Refund Policy
            </MudText>

            <MudText Class="section-text">
                Refunds are subject to the terms described in the official Refund Policy.
                Users are encouraged to review the policy before making payments.
            </MudText>


            <MudText Typo="Typo.h5" Class="section-title">
                11. Limitation of Liability
            </MudText>

            <MudText Class="section-text">
                XQARE provides career development resources and mentorship opportunities.
                However, we do not guarantee job placement, salary outcomes, or specific career results.
            </MudText>


            <MudText Typo="Typo.h5" Class="section-title">
                12. Account Suspension
            </MudText>

            <MudText Class="section-text">
                XQARE reserves the right to suspend or terminate accounts that violate these
                terms or misuse the platform.
            </MudText>


            <MudText Typo="Typo.h5" Class="section-title">
                13. Modifications
            </MudText>

            <MudText Class="section-text">
                We may update these Terms & Conditions periodically.
                Continued use of the platform after updates indicates acceptance of the revised terms.
            </MudText>


            <MudText Typo="Typo.h5" Class="section-title">
                14. Governing Law
            </MudText>

            <MudText Class="section-text">
                These Terms & Conditions are governed by the applicable laws of India.
            </MudText>


            <MudText Typo="Typo.h5" Class="section-title">
                15. Contact
            </MudText>

            <MudText Class="d-flex section-text">
                <MudIcon Icon="@Icons.Material.Filled.Email" />

                <MudLink class="ps-2" Href="mailto:support@xqare.in">
                    support@xqare.in
                </MudLink>
            </MudText>

        </MudPaper>

    </MudContainer>

    <Footer />

</section>