@page "/cookie-policy"
@using Xqare.Wrappers.CommonWrapper

<section>

    <MudPaper Class="privacy-hero">

        <MudContainer MaxWidth="MaxWidth.Large">

            <MudText Typo="Typo.h3" Align="Align.Center" Class="hero-title">
                Cookie Policy
            </MudText>

            <MudText Typo="Typo.subtitle1" Align="Align.Center" Class="hero-subtitle">
                Effective Date: January 2026
            </MudText>

        </MudContainer>

    </MudPaper>


    <MudContainer MaxWidth="MaxWidth.Medium" Class="privacy-container">

        <MudPaper Elevation="1" Class="privacy-card">

            <MudText Typo="Typo.h5" Class="section-title">
                1. What Are Cookies
            </MudText>

            <MudText Class="section-text">
                Cookies are small text files stored on your device when you visit a website.
                They help improve functionality, remember user preferences, and provide insights
                into how the platform is used.
            </MudText>


            <MudText Typo="Typo.h5" Class="section-title">
                2. How XQARE Uses Cookies
            </MudText>

            <MudText Class="section-text">
                XQARE uses cookies to enhance platform performance, analyze usage patterns,
                and provide a smoother user experience across the platform.
            </MudText>


            <MudText Typo="Typo.h5" Class="section-title">
                3. Types of Cookies We Use
            </MudText>

            <MudList T="string" Dense="true">
                <MudListItem><strong>Essential Cookies:</strong> Required for platform functionality and security.</MudListItem>
                <MudListItem><strong>Performance Cookies:</strong> Help us understand how users interact with the platform.</MudListItem>
                <MudListItem><strong>Analytics Cookies:</strong> Used to collect anonymous usage data to improve services.</MudListItem>
            </MudList>


            <MudText Typo="Typo.h5" Class="section-title">
                4. Managing Cookies
            </MudText>

            <MudText Class="section-text">
                You can control or disable cookies through your browser settings.
                However, disabling cookies may affect certain features and functionality
                of the XQARE platform.
            </MudText>


            <MudText Typo="Typo.h5" Class="section-title">
                5. Third-Party Cookies
            </MudText>

            <MudText Class="section-text">
                Some analytics and performance tools used by XQARE may place third-party cookies
                to measure traffic and improve platform performance.
            </MudText>


            <MudText Typo="Typo.h5" Class="section-title">
                6. Policy Updates
            </MudText>

            <MudText Class="section-text">
                XQARE may update this Cookie Policy from time to time.
                Any changes will be reflected on this page.
            </MudText>


            <MudText Typo="Typo.h5" Class="section-title">
                7. Contact
            </MudText>

            <MudText Class="d-flex section-text">
                <MudIcon Icon="@Icons.Material.Filled.Email" />

                <MudLink class="ps-2" Href="mailto:support@xqare.in">
                    support@xqare.in
                </MudLink>
            </MudText>

        </MudPaper>

    </MudContainer>

    <Footer />

</section>