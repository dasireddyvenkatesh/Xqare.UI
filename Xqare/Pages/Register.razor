@page "/register"
@using System.Timers
@using MudBlazor
@using Xqare.BusinessLayer.DTO
@using Xqare.BusinessLayer.Interfaces.Auth
@using Xqare.BusinessLayer.Validators
@using Xqare.BusinessLayer.Validators.FluentValidation
@inject ISnackbar Snackbar
@inject NavigationManager Nav
@inject IAuthService AuthService

<section>

    <MudGrid Class="login-wrapper" GutterSize="0">

        <!-- LEFT PANEL -->
        <MudItem xs="12" md="6" Class="left-panel d-none d-md-flex">
            <MudStack Class="left-content">

                <MudText Class="logo-text">
                    X<span>QARE</span>
                </MudText>

                @if (ShowTrialBadge)
                {
                    <MudChip T="string" Color="Color.Warning"
                             Variant="Variant.Text"
                             Class="trial-badge mt-6">
                        6-MONTH FREE TRIAL
                    </MudChip>
                }

                <MudText Class="hero-title mt-8">
                    Start your <span>career growth</span> journey today
                </MudText>

                @*                 <MudText Class="hero-sub mt-4">
                    Join 5,000+ professionals transforming their careers with XQARE.
                </MudText>

                <MudStack Spacing="3" Class="mt-8 benefits">
                    <MudText>✔ Full mentor access for 6 months</MudText>
                    <MudText>✔ Community forums & networking</MudText>
                    <MudText>✔ Curated job board access</MudText>
                    <MudText>✔ Career resources & learning paths</MudText>
                </MudStack> *@

                @if (ShowTrialPrice)
                {
                    <MudPaper Class="trial-box mt-8" Elevation="0">
                        <MudText Class="trial-price">
                            £0 <span>/ 6 months</span>
                        </MudText>
                        <MudText Class="trial-note">
                            NO CREDIT CARD REQUIRED
                        </MudText>
                    </MudPaper>
                }

            </MudStack>
        </MudItem>

        <!-- RIGHT PANEL -->
        <MudItem xs="12" md="6" Class="right-panel">

            <MudPaper Elevation="0" Class="auth-container">

                <MudText Class="mobile-logo d-block d-md-none">
                    X<span>QARE</span>
                </MudText>

                <MudText Class="auth-title">
                    Create your free account
                </MudText>

                <MudText Class="auth-subtitle">
                    Already have an account?
                    <MudButton Href="/Login">Sign in</MudButton>
                </MudText>

                @if (!isOtpStep)
                {

                    <!-- SOCIAL -->
                    <MudGrid Class="social-grid mt-6">
                        <MudItem xs="6">
                            <MudButton FullWidth Class="social-btn"
                                       StartIcon="@Icons.Custom.Brands.Google"
                                       OnClick="RegisterWithGoogle">

                                Google
                            </MudButton>
                        </MudItem>

                        <MudItem xs="6">
                            <MudButton FullWidth Class="social-btn"
                                       StartIcon="@Icons.Custom.Brands.GitHub">
                                GitHub
                            </MudButton>
                        </MudItem>

                        <MudItem xs="6">
                            <MudButton FullWidth Class="social-btn"
                                       StartIcon="@Icons.Custom.Brands.LinkedIn">
                                LinkedIn
                            </MudButton>
                        </MudItem>

                        <MudItem xs="6">
                            <MudButton FullWidth Class="social-btn"
                                       StartIcon="@Icons.Custom.Brands.Twitter">
                                Twitter
                            </MudButton>
                        </MudItem>
                    </MudGrid>

                    <!-- DIVIDER -->
                    <MudGrid Class="mt-6 mb-6 align-center">
                        <MudItem xs="5">
                            <MudDivider Class="divider-line-1" />
                        </MudItem>
                        <MudItem xs="2">
                            <MudText Class="divider-text d-flex justify-center">
                                OR SIGN UP WITH EMAIL
                            </MudText>
                        </MudItem>
                        <MudItem xs="5">
                            <MudDivider Class="divider-line-2" />
                        </MudItem>
                    </MudGrid>

                    <!-- FORM -->
                    <MudForm @ref="form"
                             Model="registerRequest"
                             Validation="validationRules.ToMudValidator()"
                             OnValidSubmit="Submit">

                        <MudTextField Label="Full Name"
                                      Variant="Variant.Outlined"
                                      @bind-Value="registerRequest.FullName"
                                      For="@(() => registerRequest.FullName)"
                                      HelperText="Please enter your legal name"
                                      HelperTextOnFocus="true"
                                      Immediate="true" />

                        <MudTextField Label="Email Address"
                                      InputType="InputType.Email"
                                      Variant="Variant.Outlined"
                                      @bind-Value="registerRequest.Email"
                                      For="@(() => registerRequest.Email)"
                                      HelperText="Please enter your personal email id"
                                      HelperTextOnFocus="true" />

                        <MudTextField Label="Password"
                                      Variant="Variant.Outlined"
                                      InputType="@(showPassword? InputType.Text: InputType.Password)"
                                      @bind-Value="registerRequest.Password"
                                      For="@(() => registerRequest.Password)"
                                      Adornment="Adornment.End"
                                      AdornmentIcon="@(showPassword? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                                      OnAdornmentClick="TogglePassword" />

                        <MudTextField Label="Confirm Password"
                                      Variant="Variant.Outlined"
                                      InputType="@(showConfirmPassword? InputType.Text: InputType.Password)"
                                      @bind-Value="registerRequest.ConfirmPassword"
                                      For="@(() => registerRequest.ConfirmPassword)"
                                      Adornment="Adornment.End"
                                      AdornmentIcon="@(showConfirmPassword? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                                      OnAdornmentClick="ToggleConfirmPassword" />

                        <MudButton Disabled="@_processing"
                                   FullWidth
                                   Variant="Variant.Filled"
                                   OnClick="Submit"
                                   Class="register-btn">
                            <MudStack Direction="Row" AlignItems="AlignItems.Center" Spacing="1">

                                @if (_processing)
                                {
                                    <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                                    <MudText>Processing...</MudText>
                                }
                                else
                                {
                                    <MudText>Register</MudText>
                                }

                            </MudStack>
                        </MudButton>

                        @if (ShowNoCardNote)
                        {
                            <MudText Class="security-text">
                                🔒 No credit card required · Cancel anytime
                            </MudText>
                        }

                        <MudText Class="signup-text">
                            By signing up, you agree to our Terms of Service & Privacy Policy
                        </MudText>

                    </MudForm>
                }
                else
                {
                    <!-- OTP FORM -->
                    <MudForm @ref="form"
                             Model="otpRequest"
                             Validation="otpValidator.ToMudValidator()"
                             OnValidSubmit="Submit"
                             Class="mt-6">

                        <MudButton Variant="Variant.Text"
                                   OnClick="BackToRegister"
                                   Class="back-btn">
                            ← Back to login
                        </MudButton>

                        <MudTextField Label="Email"
                                      Value="registerRequest.Email"
                                      Variant="Variant.Outlined"
                                      ReadOnly="true" />

                        <MudTextField Label="Enter OTP"
                                      Variant="Variant.Outlined"
                                      @bind-Value="otpRequest.OtpCode"
                                      For="@(() => otpRequest.OtpCode)"
                                      MaxLength="6"
                                      Immediate="true"
                                      InputMode="InputMode.numeric" />

                        <MudButton Variant="Variant.Text"
                                   Disabled="@isResendDisabled"
                                   OnClick="ResendOtp"
                                   Class="resend-btn">
                            @if (isResendDisabled)
                            {
                                <span>Resend in @secondsRemaining s</span>
                            }
                            else
                            {
                                <span>Resend OTP</span>
                            }
                        </MudButton>

                        <MudButton Disabled="@_processing"
                                   FullWidth
                                   Variant="Variant.Filled"
                                   OnClick="Submit"
                                   Class="register-btn">
                            <MudStack Direction="Row" AlignItems="AlignItems.Center" Spacing="1">

                                @if (_processing)
                                {
                                    <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                                    <MudText>Processing...</MudText>
                                }
                                else
                                {
                                    <MudText>Verify OTP →</MudText>
                                }

                            </MudStack>
                        </MudButton>

                    </MudForm>
                }

            </MudPaper>
        </MudItem>

    </MudGrid>
</section>

@code {

    [Parameter] public bool ShowTrialBadge { get; set; } = false;
    [Parameter] public bool ShowTrialPrice { get; set; } = false;
    [Parameter] public bool ShowNoCardNote { get; set; } = false;

    MudForm form = new();
    RegisterRequest registerRequest = new();
    VerifyEmailOtpRequest otpRequest = new();

    RegisterRequestValidator validationRules = new();
    OtpRequestValidator otpValidator = new();

    private bool _processing = false;
    bool isOtpStep = false;
    bool showPassword;
    bool showConfirmPassword;
    bool isResendDisabled = true;
    int secondsRemaining = 30;
    Timer timer = new();

    void TogglePassword() => showPassword = !showPassword;
    void ToggleConfirmPassword() => showConfirmPassword = !showConfirmPassword;

    async Task Submit()
    {
        await form.ValidateAsync();

        if (!form.IsValid)
            return;

        _processing = true;

        try
        {

            if (!isOtpStep)
            {
                // STEP 1: REGISTER
                var response = await AuthService.RegisterAsync(registerRequest);

                if (!response.IsSuccess)
                {
                    Snackbar.Add(response.Message, Severity.Error);
                    return;
                }

                if (response.RequiresEmailVerification)
                {
                    otpRequest.Email = registerRequest.Email;
                    isOtpStep = true;

                    Snackbar.Add(response.Message);
                    StartTimer();
                    return;
                }
            }
            else
            {
                // STEP 2: VERIFY OTP
                var otpResponse = await AuthService.VerifyOtpAsync(otpRequest);

                if (!otpResponse.IsSuccess)
                {
                    Snackbar.Add("Invalid OTP", Severity.Error);
                    return;
                }

                Snackbar.Add("Registration successful", Severity.Success);
                Nav.NavigateTo("/dashboard");
            }
        }
        catch
        {
            Snackbar.Add("Something went wrong. Please try again.", Severity.Error);
        }
        finally
        {
            _processing = false;
        }
    }

    async Task ResendOtp()
    {
        var response = await AuthService.ResendOtpAsync(registerRequest.Email);

        if (response)
        {
            Snackbar.Add("OTP resent", Severity.Success);
            StartTimer();
        }
        else
        {
            Snackbar.Add("Failed to resend OTP", Severity.Error);
        }


    }

    void StartTimer()
    {
        isResendDisabled = true;
        secondsRemaining = 30;

        timer?.Dispose();

        timer = new Timer(1000);
        timer.Elapsed += OnTimerTick;
        timer.Start();
    }

    void OnTimerTick(object? sender, ElapsedEventArgs e)
    {
        InvokeAsync(() =>
        {
            if (secondsRemaining > 0)
                secondsRemaining--;
            else
            {
                isResendDisabled = false;
                timer.Stop();
            }

            StateHasChanged();
        });
    }

    void BackToRegister()
    {
        isOtpStep = false;
        otpRequest = new();
    }

    async Task RegisterWithGoogle()
    {
        await AuthService.LoginWithGoogle();
    }
    async Task RegisterWithGitHub()
    {
        await AuthService.LoginWithGitHub();
    }

    async Task RegisterWithLinkedIn()
    {
        await AuthService.LoginWithLinkedIn();
    }

    async Task RegisterWithTwitter()
    {
        await AuthService.LoginWithTwitter();
    }
}