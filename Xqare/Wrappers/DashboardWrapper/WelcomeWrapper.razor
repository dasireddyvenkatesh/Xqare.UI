@using MudBlazor

<section class="welcome-wrapper">

    <div class="welcome-card">

        <!-- Left Content -->
        <div class="welcome-content">

            <MudText Typo="Typo.h4" Class="welcome-title">
                Welcome back, 👋
            </MudText>

            <MudText Typo="Typo.body1" Class="welcome-subtitle">
                Start building your career with clarity.
            </MudText>

            <div class="welcome-actions">

                <MudButton Variant="Variant.Filled"
                           Color="Color.Warning"
                           Class="primary-btn">
                    Join Community
                </MudButton>

                <MudButton Variant="Variant.Outlined"
                           Color="Color.Default"
                           Class="secondary-btn">
                    Complete Profile
                </MudButton>

            </div>

            <MudText Typo="Typo.caption" Class="welcome-footer">
                More features — including mentorship, career opportunities, and AI-powered tools — are coming soon.
            </MudText>

        </div>

    </div>

</section>