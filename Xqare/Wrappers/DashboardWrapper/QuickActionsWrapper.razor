@using MudBlazor

<section class="quick-actions">

    <div class="actions-grid">

        <!-- Community -->
        <div class="action-card">
            <MudIcon Icon="@Icons.Material.Filled.Group" Class="action-icon" />

            <MudText Typo="Typo.h6" Class="action-title">
                Community
            </MudText>

            <MudText Typo="Typo.body2" Class="action-desc">
                Join discussions and connect with peers.
            </MudText>
        </div>

        <!-- Profile -->
        <div class="action-card">
            <MudIcon Icon="@Icons.Material.Filled.Person" Class="action-icon" />

            <MudText Typo="Typo.h6" Class="action-title">
                Complete Profile
            </MudText>

            <MudText Typo="Typo.body2" Class="action-desc">
                Add details to unlock better opportunities.
            </MudText>
        </div>

        <!-- Insights -->
        <div class="action-card">
            <MudIcon Icon="@Icons.Material.Filled.Lightbulb" Class="action-icon" />

            <MudText Typo="Typo.h6" Class="action-title">
                Career Insights
            </MudText>

            <MudText Typo="Typo.body2" Class="action-desc">
                Explore curated content to guide your growth
            </MudText>
        </div>

    </div>

</section>