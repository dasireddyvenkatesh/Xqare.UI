@using MudBlazor

<section class="insights-wrapper">

    <div class="insights-card">

        <!-- Header -->
        <div class="insights-header">
            <MudText Typo="Typo.h6" Class="insights-title">
                Latest Insights
            </MudText>

            <MudText Class="view-all">
                View All →
            </MudText>
        </div>

        <!-- Items -->
        <div class="insights-list">

            <div class="insight-item">
                <div>
                    <div class="insight-title">How to choose the right career path</div>
                    <div class="insight-desc">
                        A practical guide for early-career professionals navigating options.
                    </div>
                </div>
                <MudIcon Icon="@Icons.Material.Filled.ArrowForward" />
            </div>

            <div class="insight-item">
                <div>
                    <div class="insight-title">Skills that matter in 2026</div>
                    <div class="insight-desc">
                        The most in-demand skills employers are looking for this year.
                    </div>
                </div>
                <MudIcon Icon="@Icons.Material.Filled.ArrowForward" />
            </div>

            <div class="insight-item">
                <div>
                    <div class="insight-title">Building your professional network</div>
                    <div class="insight-desc">
                        Strategies to connect with the right people in your industry.
                    </div>
                </div>
                <MudIcon Icon="@Icons.Material.Filled.ArrowForward" />
            </div>

            <div class="insight-item">
                <div>
                    <div class="insight-title">Remote work best practices</div>
                    <div class="insight-desc">
                        Stay productive and visible while working from anywhere.
                    </div>
                </div>
                <MudIcon Icon="@Icons.Material.Filled.ArrowForward" />
            </div>

        </div>

    </div>

</section>