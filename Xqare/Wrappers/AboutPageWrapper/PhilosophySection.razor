@using MudBlazor
<section class="philosophy-wrapper">

    <MudContainer MaxWidth="MaxWidth.Medium">

        <MudStack AlignItems="AlignItems.Center"
                  Spacing="2"
                  Class="philosophy-content">

            <!-- Tag -->
            <MudText Class="section-tag">
                OUR BELIEF
            </MudText>

            <!-- Title -->
            <MudText Typo="Typo.h4" Class="philosophy-title">
                Our Philosophy
            </MudText>

            <!-- Line 1 -->
            <MudText Class="philosophy-text">
                Careers are not built by chance.
            </MudText>

            <!-- Line 2 -->
            <MudText Class="philosophy-text">
                They are built through <b>clarity, guidance, and continuous growth.</b>
            </MudText>

            <!-- Divider -->
            <MudText Class="philosophy-sub">
                This belief defines our brand message:
            </MudText>

            <!-- BIG STATEMENT -->
            <MudText Typo="Typo.h2" Class="philosophy-highlight">
                Build Who You Are.
            </MudText>

            <!-- Closing -->
            <MudText Class="philosophy-footer">
                Because your career should reflect your <b>potential</b> — not your limitations.
            </MudText>

        </MudStack>

    </MudContainer>

</section>