@using MudBlazor
<section class="vision-wrapper">

    <MudContainer MaxWidth="MaxWidth.Medium">

        <MudStack AlignItems="AlignItems.Center"
                  Spacing="2"
                  Class="vision-content">

            <!-- Tag -->
            <MudText Class="section-tag">
                LOOKING AHEAD
            </MudText>

            <!-- Title -->
            <MudText Typo="Typo.h4" Align="Align.Center" Class="vision-title">
                Our Vision
            </MudText>

            <!-- Main Statement -->
            <MudText Align="Align.Center" Class="vision-highlight">
                Our long-term vision is to build one of the most trusted global platforms for
                <span>career growth, mentorship, and real job opportunities.</span>
            </MudText>

            <!-- Paragraph -->
            <MudText Align="Align.Center" Class="vision-text">
                A place where individuals can continuously evolve their careers, connect with mentors,
                and access meaningful opportunities — all within one powerful ecosystem.
            </MudText>

            <!-- Paragraph -->
            <MudText Align="Align.Center" Class="vision-text">
                We believe that when people receive the right guidance and support,
                they can build <strong>extraordinary careers.</strong>
            </MudText>

            <!-- Bottom line accent -->
            <div class="vision-line"></div>

        </MudStack>

    </MudContainer>

</section>