@using MudBlazor
<section class="founders-wrapper">

    <MudContainer MaxWidth="MaxWidth.Medium">

        <MudGrid AlignItems="Center" Spacing="4">

            <!-- LEFT -->
            <MudItem xs="12" md="6">

                <div class="founders-content">

                    <!-- Pill Tag -->
                    <div class="founders-badge">
                        <MudIcon Icon="@Icons.Material.Filled.EmojiEvents" />
                        EARLY BELIEVERS
                    </div>

                    <!-- Title -->
                    <MudText Typo="Typo.h4" Class="founders-title">
                        Founding Members of <span>XQARE</span>
                    </MudText>

                    <!-- Description -->
                    <MudText Class="founders-text">
                        Our early members are recognized as XQARE Founding Members — individuals who believed in the vision and joined the platform at the beginning.
                    </MudText>

                    <!-- Sub Heading -->
                    <MudText Class="founders-subtitle">
                        <b>Founding Members receive:</b>
                    </MudText>

                    <!-- List -->
                    <ul class="founders-list">

                        <li>
                            <span class="check-icon"></span>
                            Lifetime platform membership
                        </li>

                        <li>
                            <span class="check-icon"></span>
                            Early access to new features
                        </li>

                        <li>
                            <span class="check-icon"></span>
                            Exclusive founding member recognition
                        </li>

                        <li>
                            <span class="check-icon"></span>
                            A special founding member digital badge
                        </li>

                    </ul>

                    <!-- Note -->
                    <MudText Class="founders-note">
                        Their support plays an important role in shaping the future of the platform and community.
                    </MudText>

                </div>

            </MudItem>

            <!-- RIGHT -->
            <MudItem xs="12" md="6">

                <div class="founders-image-wrapper">

                    <div class="founders-glow">
                        <img src="images/founding-badge.png" alt="Founding Badge" />
                    </div>

                </div>

            </MudItem>

        </MudGrid>

    </MudContainer>

</section>