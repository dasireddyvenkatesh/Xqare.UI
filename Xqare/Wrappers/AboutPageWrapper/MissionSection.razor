@using MudBlazor
<section class="mission-wrapper">

    <MudContainer MaxWidth="MaxWidth.Large">

        <MudGrid AlignItems="Center" Spacing="4">

            <!-- LEFT: Circle UI -->
            <MudItem xs="12" md="6">

                <div class="orbit-container">

                    <!-- Outer Circles -->
                    <div class="orbit orbit-1"></div>
                    <div class="orbit orbit-2"></div>
                    <div class="orbit orbit-3"></div>

                    <!-- Center Content -->
                    <div class="orbit-center">
                        <MudIcon Icon="@Icons.Material.Filled.TrackChanges" />
                        <MudText Typo="Typo.h6">Guidance</MudText>
                        <MudText Typo="Typo.caption">& Growth</MudText>
                    </div>

                    <!-- Floating Icons -->
                    <MudIcon Icon="@Icons.Material.Filled.MenuBook" Class="orbit-icon icon-top" />
                    <MudIcon Icon="@Icons.Material.Filled.TrendingUp" Class="orbit-icon icon-right" />
                    <MudIcon Icon="@Icons.Material.Filled.Groups" Class="orbit-icon icon-bottom" />
                    <MudIcon Icon="@Icons.Material.Filled.School" Class="orbit-icon icon-left" />

                </div>

            </MudItem>

            <!-- RIGHT: Content -->
            <MudItem xs="12" md="6">

                <div class="mission-content">

                    <MudText Class="section-tag">OUR MISSION</MudText>

                    <MudText Typo="Typo.h4" Class="mission-title">
                        Empowering You to
                        <span class="highlight">Build Who You Are</span>
                    </MudText>

                    <MudText Class="mission-text">
                        At XQARE, our mission is simple but powerful: to empower individuals
                        to build who they truly are — professionally and personally.
                    </MudText>

                    <MudText Class="mission-text">
                        In today's fast-changing world, career growth is no longer linear.
                        People need guidance, clarity, and real insights to navigate their paths.
                    </MudText>

                    <MudText Class="mission-text">
                        XQARE was created to bridge this gap by bringing together mentorship,
                        community, and modern career resources into one unified ecosystem.
                    </MudText>

                </div>

            </MudItem>

        </MudGrid>

    </MudContainer>

</section>