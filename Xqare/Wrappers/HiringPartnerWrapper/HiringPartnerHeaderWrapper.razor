@using MudBlazor

<section class="partner-hero">
    <MudContainer MaxWidth="MaxWidth.Large" Class="hero-container">

        <MudChip T="string" Color="Color.Warning"
                 Variant="Variant.Outlined"
                 Class="hero-chip">
            <MudIcon Icon="@Icons.Material.Filled.Handshake" Size="Size.Small" Class="me-2"/>
            Hiring Partnership
        </MudChip>

        <MudText Typo="Typo.h2" Class="hero-title">
            Partner With XQARE
        </MudText>

        <MudText Typo="Typo.subtitle1" Class="hero-subtitle">
            Connect with skilled, mentorship-trained professionals ready to make an impact.
            XQARE helps companies discover and hire top talent through a curated career ecosystem.
        </MudText>

    </MudContainer>
</section>

