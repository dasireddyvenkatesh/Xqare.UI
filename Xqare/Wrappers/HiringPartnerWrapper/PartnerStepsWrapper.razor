@using MudBlazor

<section class="steps-section">

    <MudContainer MaxWidth="MaxWidth.Medium">

        <MudText Typo="Typo.h4" Class="steps-title">
            How the Partnership Works
        </MudText>

        <MudGrid Class="steps-grid" AlignItems="Center" Justify="Justify.Center">

            <MudItem xs="12" md="2" Class="step-item">
                <div class="step-circle">1</div>
                <MudText Class="step-text">
                    Submit Partnership Inquiry
                </MudText>
            </MudItem>

            <MudItem md="1" Class="arrow-item d-none d-md-flex">
                <MudIcon Icon="@Icons.Material.Filled.ArrowForward" />
            </MudItem>

            <MudItem xs="12" md="2" Class="step-item">
                <div class="step-circle">2</div>
                <MudText Class="step-text">
                    XQARE Team Reviews Your Requirements
                </MudText>
            </MudItem>

            <MudItem md="1" Class="arrow-item d-none d-md-flex">
                <MudIcon Icon="@Icons.Material.Filled.ArrowForward" />
            </MudItem>

            <MudItem xs="12" md="2" Class="step-item">
                <div class="step-circle">3</div>
                <MudText Class="step-text">
                    Onboarding & Talent Pipeline Setup
                </MudText>
            </MudItem>

            <MudItem md="1" Class="arrow-item d-none d-md-flex">
                <MudIcon Icon="@Icons.Material.Filled.ArrowForward" />
            </MudItem>

            <MudItem xs="12" md="2" Class="step-item">
                <div class="step-circle">4</div>
                <MudText Class="step-text">
                    Start Receiving Matched Candidates
                </MudText>
            </MudItem>

        </MudGrid>

    </MudContainer>

</section>