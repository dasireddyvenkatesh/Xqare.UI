@using MudBlazor

<section class="features-section">

    <MudContainer MaxWidth="MaxWidth.Large">

        <MudGrid GutterSize="3">

            <MudItem xs="12" sm="6" md="3">
                <MudCard Class="feature-card">
                    <MudCardContent>

                        <div class="icon-box">
                            <MudIcon Icon="@Icons.Material.Filled.Group" />
                        </div>

                        <MudText Typo="Typo.h6" Class="card-title">
                            Access Vetted Talent
                        </MudText>

                        <MudText Typo="Typo.body2" Class="card-desc">
                            Connect with skilled professionals who have been mentored and validated through the XQARE ecosystem.
                        </MudText>

                    </MudCardContent>
                </MudCard>
            </MudItem>

            <MudItem xs="12" sm="6" md="3">
                <MudCard Class="feature-card">
                    <MudCardContent>

                        <div class="icon-box">
                            <MudIcon Icon="@Icons.Material.Filled.TrackChanges" />
                        </div>

                        <MudText Typo="Typo.h6" Class="card-title">
                            Targeted Hiring
                        </MudText>

                        <MudText Typo="Typo.body2" Class="card-desc">
                            Our AI-powered matching recommends candidates whose skills align with your open roles.
                        </MudText>

                    </MudCardContent>
                </MudCard>
            </MudItem>

            <MudItem xs="12" sm="6" md="3">
                <MudCard Class="feature-card">
                    <MudCardContent>

                        <div class="icon-box">
                            <MudIcon Icon="@Icons.Material.Filled.Bolt" />
                        </div>

                        <MudText Typo="Typo.h6" Class="card-title">
                            Faster Time-to-Hire
                        </MudText>

                        <MudText Typo="Typo.body2" Class="card-desc">
                            Reduce hiring cycles by engaging with candidates who are interview-ready.
                        </MudText>

                    </MudCardContent>
                </MudCard>
            </MudItem>

            <MudItem xs="12" sm="6" md="3">
                <MudCard Class="feature-card">
                    <MudCardContent>

                        <div class="icon-box">
                            <MudIcon Icon="@Icons.Material.Filled.BarChart" />
                        </div>

                        <MudText Typo="Typo.h6" Class="card-title">
                            Pipeline Visibility
                        </MudText>

                        <MudText Typo="Typo.body2" Class="card-desc">
                            Track candidate progress from application to offer with a transparent hiring dashboard.
                        </MudText>

                    </MudCardContent>
                </MudCard>
            </MudItem>

        </MudGrid>

    </MudContainer>

</section>